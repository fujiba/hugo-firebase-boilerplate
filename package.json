{
  "name": "hugo-firebase-boilerplate",
  "version": "0.1.0",
  "description": "Boilerplate for Firebase with Hugo contents.",
  "scripts": {
    "deploy:prod": "(cd website && hugo --minify) && firebase deploy --only hosting:prod",
    "init": "scripts/init-setup.sh",
    "deploy:dev": "scripts/deploy-dev.sh",
    "serve": "(cd website && hugo server)"
  },
  "author": "T.Fujiba",
  "license": "MIT",
  "devDependencies": {
    "eslint": "9.2.0",
    "eslint-config-prettier": "9.1.0",
    "firebase-tools": "15.10.0",
    "prettier": "3.2.5"
  },
  "pnpm": {
    "overrides": {
      "@tootallnate/once": "3.0.1",
      "flatted@<=3.4.1": "3.4.2",
      "path-to-regexp@<0.1.13": "0.1.13",
      "path-to-regexp@>=8.0.0 <8.4.0": "8.4.0",
      "brace-expansion@<1.1.13": "1.1.13",
      "brace-expansion@>=2.0.0 <2.0.3": "2.0.3",
      "brace-expansion@>=4.0.0 <5.0.5": "5.0.5",
      "picomatch@<2.3.2": "2.3.2",
      "picomatch@>=4.0.0 <4.0.4": "4.0.4",
      "yaml@>=2.0.0 <2.8.3": "2.8.3",
      "lodash@<4.17.21": "4.17.21",
      "hono@<4.12.18": "4.12.18",
      "@hono/node-server@<1.19.13": "1.19.13",
      "basic-ftp@<5.3.1": "5.3.1",
      "protobufjs@<7.5.5": "7.5.5",
      "ip-address@<=10.1.0": "10.1.1",
      "fast-uri@<3.1.2": "3.1.2"
    }
  }
}
